# Room2Learn Environment Configuration
# Copy this file to .env and fill in real values

# Mock mode: set to "false" to use real AI services
USE_MOCKS=true

# AI API keys (only needed when USE_MOCKS=false)
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
OPENROUTER_API_KEY=your-openrouter-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Vapi voice host (only needed when USE_MOCKS=false)
VAPI_API_KEY=your-key
VAPI_PUBLIC_KEY=your-vapi-public-key-here
VAPI_VOICE_ID=xrNwYO0xeioXswMCcFNF
VAPI_MODEL_ID=gemini-2.5-flash-lite

# Image generation (only needed when USE_MOCKS=false)
IMAGE_GEN_API_KEY=your-image-gen-key-here
ROOM_ID_PREFIX=room

# Room builder stub mode (set to "true" to skip real API calls and use pre-built stubs)
STUB_ROOM_BUILDER=false

# VRESC integration paths
VRESC_PROD_DIR=./VRESC-prod

# Server settings
HOST=0.0.0.0
PORT=8000

# Processing delay per step in seconds (mock mode only)
MOCK_STEP_DELAY=2.5
